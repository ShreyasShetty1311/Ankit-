rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: urls
    // Document ID: auto-generated
    // Fields:
    //   - originalUrl: string (required, uri)
    //   - shortId: string (required, unique)
    //   - clickCount: number (required, default 0)
    //   - createdAt: timestamp (required)
    //   - category: string (optional)
    //
    // ===============================================================

    // Helper Functions
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidShortId(id) {
      return id is string && id.size() >= 6 && id.size() <= 12;
    }

    function isValidUrlDoc(data) {
      return data.keys().hasAll(['originalUrl', 'shortId', 'clickCount', 'createdAt']) &&
             isValidUrl(data.originalUrl) &&
             isValidShortId(data.shortId) &&
             data.clickCount is number &&
             data.createdAt is timestamp;
    }

    match /urls/{urlId} {
      // Publicly readable for redirection and analytics
      allow read: if true;
      
      // Anyone can create a short URL
      allow create: if isValidUrlDoc(request.resource.data) && 
                      request.resource.data.clickCount == 0;
      
      // Only clickCount can be incremented by anyone
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clickCount']) &&
                      request.resource.data.clickCount == resource.data.clickCount + 1 &&
                      request.resource.data.originalUrl == resource.data.originalUrl &&
                      request.resource.data.shortId == resource.data.shortId;
                      
      allow delete: if false;
    }
  }
}
